<Window x:Class="DevLauncher.ProfileNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nouveau profil"
        Height="150" Width="350"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource DarkBgBrush}"
        FontFamily="Segoe UI">
    <StackPanel Margin="20">
        <TextBlock Text="Nom du profil :"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   FontSize="13" Margin="0,0,0,8"/>
        <TextBox x:Name="NameBox"
                 Background="#2A2A3E"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 BorderBrush="#444466"
                 FontSize="13" Padding="8,6"
                 KeyDown="NameBox_KeyDown"/>
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Annuler"
                    Style="{StaticResource PrimaryButton}"
                    FontSize="12" Padding="12,6"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Créer"
                    Style="{StaticResource SuccessButton}"
                    FontSize="12" Padding="12,6"
                    Click="Confirm_Click"/>
        </StackPanel>
    </StackPanel>
</Window>